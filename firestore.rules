rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: journalEntries
    // Fields: title (string), content (string), mood (string), tags (list), createdAt (timestamp), updatedAt (timestamp), userId (string)
    //
    // Collection: moodLogs
    // Fields: mood (int), emoji (string), note (string), createdAt (timestamp), userId (string)
    //
    // Collection: tasks
    // Fields: title (string), priority (string), deadline (timestamp), completed (bool), createdAt (timestamp), userId (string)
    //
    // Collection: userPreferences
    // Fields: theme (string), colorTheme (string), notificationsEnabled (bool), userId (string)
    //
    // Collection: savedInspirations
    // Fields: quote (string), author (string), savedAt (timestamp), userId (string)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidJournal(data) {
      return data.content is string && data.content.size() > 0 && data.content.size() < 50000 &&
             data.userId == request.auth.uid;
    }

    function isValidMood(data) {
      return data.mood is int && data.mood >= 1 && data.mood <= 5 &&
             data.userId == request.auth.uid;
    }

    function isValidTask(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 1000 &&
             data.userId == request.auth.uid;
    }

    function isValidPreference(data) {
      return data.userId == request.auth.uid;
    }

    function isValidInspiration(data) {
      return data.quote is string && data.quote.size() > 0 &&
             data.userId == request.auth.uid;
    }

    // Rules
    match /journalEntries/{entryId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidJournal(request.resource.data);
      allow update: if isDocOwner() && isValidJournal(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /moodLogs/{logId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidMood(request.resource.data);
      allow update: if isDocOwner() && isValidMood(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /tasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidTask(request.resource.data);
      allow update: if isDocOwner() && isValidTask(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /userPreferences/{prefId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidPreference(request.resource.data);
      allow update: if isDocOwner() && isValidPreference(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /savedInspirations/{inspId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidInspiration(request.resource.data);
      allow update: if isDocOwner() && isValidInspiration(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
